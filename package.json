{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build && node ./artifacts/api-server/dist/index.mjs",
    "build": "npm run build --workspaces --if-present",
    "start": "node ./artifacts/api-server/dist/index.mjs"
  },
  "private": true,
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.8.4",
    "typescript": "~5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "scripts"
  ],
  "dependencies": {
    "@google/genai": "^2.10.0"
  }
}
